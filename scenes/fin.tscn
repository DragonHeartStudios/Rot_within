[node name="RichTextLabel" type="RichTextLabel" parent="prison/MarginContainer" unique_id=850859707]
layout_mode = 2
text = "The deadline has passed. Henkins didn't wait a single minute to rat you out. Sirens are wailing outside your house.
Thrown into a dark cell, you await your trial. But the rot growing inside you doesn't stop behind bars. Without the work to distract you, the mutation accelerates. Day after day, your skin deteriorates, your posture bending under the weight of your regrets and dishonesty. The guards avoid your cell, terrified by the sounds escaping from it.
Henkins threw you in prison to punish you, but he condemned you to become the monster you were hiding within."
scroll_active = false
horizontal_alignment = 1

