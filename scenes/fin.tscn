[node name="RichTextLabel" type="RichTextLabel" parent="ruinne/MarginContainer" unique_id=62988705]
layout_mode = 2
text = "You ran out of money before you could pay off your debt.
Little by little, everything was taken from you. Your food, your home, your dignity. Soon, all you had left were the streets. Cold nights. Empty stomach. Endless regret. Henkins never got his money back. You never became a monster. But sometimes... A ruined man is harder to look at than one."
scroll_active = false
horizontal_alignment = 1

