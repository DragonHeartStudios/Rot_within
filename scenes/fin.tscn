[node name="RichTextLabel" type="RichTextLabel" parent="apocalypse/MarginContainer" unique_id=1022356861]
layout_mode = 2
text = "You served radioactive food to every single customer. One by one, they began to mutate. Bones twisted, skin rotted, humanity faded.
Soon, the infection spread across the entire city. The streets became chaos, mutants hunted the living, and the bitten turned into monsters themselves.
Screams echoed through every alley. No one was safe anymore.
The city is contaminated.
You paid your debt... but doomed everyone else."
scroll_active = false
horizontal_alignment = 1

